rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funciones de utilidad
    function isLoggedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Verifica si el usuario tiene una relación activa con el niño
    // Basado en el ID determinista: userId_childId
    function hasAccess(childId) {
      let accessPath = /databases/$(database)/documents/child_access/$(request.auth.uid + "_" + childId);
      return exists(accessPath) && get(accessPath).data.isActive == true;
    }

    // Verifica si el usuario es el creador del documento del niño
    function isCreator(childId) {
      let childPath = /databases/$(database)/documents/children/$(childId);
      return exists(childPath) && get(childPath).data.createdBy == request.auth.uid;
    }
    
    // Reglas para Perfiles de Usuario
    match /users/{userId} {
      allow read, write: if isLoggedIn() && isOwner(userId);
    }
    
    // Reglas para Relaciones de Acceso
    match /child_access/{accessId} {
      allow read: if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; 
    }
    
    // Reglas para Niños y sus Subcolecciones
    match /children/{childId} {
      // Un usuario puede leer/escribir si es el creador o tiene acceso concedido
      allow read, write: if isLoggedIn() && (resource == null || resource.data.createdBy == request.auth.uid || hasAccess(childId));
      
      // Subcolecciones protegidas por el acceso al niño
      // Se permite acceso si es el creador del perfil del niño o tiene un registro en child_access
      match /assessments/{id} { allow read, write: if isLoggedIn() && (isCreator(childId) || hasAccess(childId)); }
      match /learning_plans/{id} { allow read, write: if isLoggedIn() && (isCreator(childId) || hasAccess(childId)); }
      match /game_sessions/{id} { allow read, write: if isLoggedIn() && (isCreator(childId) || hasAccess(childId)); }
      match /game_progress/{id} { allow read, write: if isLoggedIn() && (isCreator(childId) || hasAccess(childId)); }
      match /child_rewards/{id} { allow read, write: if isLoggedIn() && (isCreator(childId) || hasAccess(childId)); }
    }
    
    // Reglas para el catálogo de Recompensas (Metadata)
    match /rewards/{rewardId} {
      allow read: if isLoggedIn();
      allow write: if false;
    }
  }
}