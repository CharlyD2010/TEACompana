
{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["parent", "teacher", "admin"] },
        "avatarKey": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "institutionId": { "type": "string" },
        "institutionName": { "type": "string" },
        "assignedGroups": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "fullName", "email", "role"]
    },
    "Child": {
      "title": "Child",
      "description": "Child profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "createdBy": { "type": "string", "description": "UID of the creator" },
        "name": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "teaLevel": { "type": "string", "enum": ["leve", "moderado", "severo"] },
        "interests": { "type": "array", "items": { "type": "string" } },
        "learningStyle": { "type": "string", "enum": ["visual", "auditivo", "kinestésico", "mixto"] },
        "avatarUrl": { "type": "string" },
        "avatarKey": { "type": "string" },
        "medicalNotes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "points": { "type": "number" },
        "stars": { "type": "number" },
        "institutionId": { "type": "string" },
        "institutionName": { "type": "string" },
        "groupId": { "type": "string" },
        "groupName": { "type": "string" }
      },
      "required": ["id", "createdBy", "name", "teaLevel", "institutionId", "groupId"]
    },
    "Assessment": {
      "title": "Initial Assessment",
      "description": "Initial developmental assessment scores",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "childId": { "type": "string" },
        "conductedBy": { "type": "string" },
        "scores": {
          "type": "object",
          "properties": {
            "emociones": { "type": "number" },
            "comunicacion": { "type": "number" },
            "social": { "type": "number" },
            "cognitivo": { "type": "number" },
            "motricidad": { "type": "number" },
            "rutinas": { "type": "number" }
          }
        },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "LearningPlan": {
      "title": "Learning Plan",
      "description": "AI generated learning plan",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "childId": { "type": "string" },
        "priorityAreas": { "type": "array", "items": { "type": "string" } },
        "weeklyGoals": { "type": "array", "items": { "type": "string" } },
        "recommendedActivities": { "type": "array", "items": { "type": "string" } },
        "suggestionsForParents": { "type": "array", "items": { "type": "string" } },
        "suggestionsForTeachers": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "TeacherObservation": {
      "title": "Teacher Observation",
      "description": "Observation or recommendation from a teacher to a parent",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "childId": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "message": { "type": "string" },
        "recommendationType": { "type": "string", "enum": ["progreso", "conducta", "actividad", "seguimiento"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "visibleToParent": { "type": "boolean" }
      },
      "required": ["id", "childId", "teacherId", "teacherName", "message", "recommendationType"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Registered user profiles"
    },
    "/children/{childId}": {
      "schema": "Child",
      "description": "Children profiles"
    },
    "/children/{childId}/assessments/{assessmentId}": {
      "schema": "Assessment",
      "description": "Assessments per child"
    },
    "/children/{childId}/learning_plans/{planId}": {
      "schema": "LearningPlan",
      "description": "Learning plans per child"
    },
    "/children/{childId}/teacher_observations/{obsId}": {
      "schema": "TeacherObservation",
      "description": "Teacher observations for a child"
    }
  }
}
